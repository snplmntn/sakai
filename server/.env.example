NODE_ENV=development
PORT=3000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_GOOGLE_REDIRECT_URI=https://your-api.example.com/api/auth/google/callback
AUTH_APP_REDIRECT_URI=sakai://auth/callback
AUTH_STATE_SIGNING_SECRET=replace-with-a-long-random-secret-at-least-32-characters
AI_PROVIDER=gemini_developer
GEMINI_API_KEY=your-gemini-developer-api-key
GOOGLE_API_KEY=your-google-ai-api-key
# Optional only if switching AI_PROVIDER to vertex_express
VERTEX_API_KEY=
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_LIGHT=gemini-2.5-flash-lite
MMDA_SOURCE_URLS=https://x.com/MMDA,https://mmda.gov.ph/mmda-social-media.html
# Optional. Defaults to true in development/production and false in test.
MMDA_REFRESH_ENABLED=true
MMDA_REFRESH_INTERVAL_MINUTES=15
# Optional. Defaults to true in development/production and false in test.
MMDA_BROWSER_FALLBACK_ENABLED=true
# Optional when Chromium is not on the default PATH for your server.
MMDA_BROWSER_EXECUTABLE_PATH=
MMDA_BROWSER_TIMEOUT_MS=20000
